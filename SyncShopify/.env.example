# ============================================================
#  Configuración - Sync Shopify
#  Copia este archivo como .env y completa los valores
# ============================================================

# Tienda Shopify (sin https://)
SHOPIFY_STORE=kunqhm-km.myshopify.com

# Credenciales OAuth de Shopify (para obtener token temporal)
SHOPIFY_CLIENT_ID=tu_client_id_aqui
SHOPIFY_CLIENT_SECRET=tu_client_secret_aqui

# URL completa de la API de inventario (incluye api_key)
API_URL=http://186.97.200.50:8090/api/inventario?api_key=TU_API_KEY_AQUI

# Límite de productos a sincronizar para pruebas.
# 0 = sincronizar todos
# 3 = sincronizar solo 3 productos
SYNC_LIMIT=3
