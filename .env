# ============================================================
#  .env  — Configuración de producción (servidor remoto)
#  Renombrar este archivo a ".env" y ajustar los valores
# ============================================================

FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=keypersonal123_remotocentro
API_KEY=cj2026-K9mPxLw8Q2nR5jT3bY7dH0AC1fE4

# ----------------------------------------------------------
#  RUTA A LOS DATOS DBF
#
#  DBF_BASE_PATH apunta a la carpeta que CONTIENE las
#  subcarpetas DbfRed. La API elige automáticamente la más
#  reciente en cada ciclo de sincronización.
#
#  En este servidor la carpeta se accede por red:
#    DBF_BASE_PATH=\\192.168.10.10\e\Servidor Delfin\manual por hora
# ----------------------------------------------------------
DBF_BASE_PATH=\\192.168.10.10\e\Servidor Delfin\manual por hora

# Fallback si DBF_BASE_PATH no existe (ruta fija a una carpeta concreta)
DBF_PATH=DbfRed 2025-12-09 17;02;02\DbfRed 2025-12-09 17;02;02

# Encoding de los archivos DBF de FoxPro
DBF_ENCODING=latin-1

# ----------------------------------------------------------
#  SINCRONIZACIÓN
#  Las carpetas DbfRed se generan cada ~40 minutos.
#  Con 10 minutos el peor caso de demora es 9 minutos.
# ----------------------------------------------------------
SYNC_INTERVAL_MINUTES=10

# ----------------------------------------------------------
#  SERVIDOR
# ----------------------------------------------------------
PORT=8090
HOST=0.0.0.0

# CORS: * permite cualquier origen. Para restringir:
#   ALLOWED_ORIGINS=http://192.168.1.50,http://192.168.1.51
ALLOWED_ORIGINS=*

# ----------------------------------------------------------
#  CACHÉ  (segundos)
#  3 horas cubre varias rotaciones de carpeta sin problema
# ----------------------------------------------------------
CACHE_TIMEOUT=10800

# ----------------------------------------------------------
#  LOGGING
# ----------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
